{
    "fields": {
        "name": {
            "type": "varchar",
            "required": true,
            "pattern": "$noBadCharacters"
        },
        "description": {
            "type": "text"
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true
        },
        "createdBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "assignedUser": {
            "type": "link",
            "required": false,
            "view": "views/fields/assigned-user"
        },
        "teams": {
            "type": "linkMultiple",
            "view": "views/fields/teams"
        },
        "challange": {
            "type": "wysiwyg",
            "isCustom": true
        },
        "solution": {
            "type": "wysiwyg",
            "isCustom": true
        },
        "businessBenefits": {
            "type": "wysiwyg",
            "isCustom": true
        },
        "aboutClient": {
            "type": "wysiwyg",
            "isCustom": true
        },
        "technology": {
            "type": "enum",
            "options": [
                "Zoho CRM",
                "Zoho Desk",
                "Zoho Creator",
                "Hubspot",
                "Zoho website",
                "Odoo",
                "Salesforce",
                "Asp.net",
                "Asp.net Core",
                "Laravel",
                "Wordpress",
                "Mobile App",
                "Shopify",
                "Magento",
                "Woocomerce",
                "SFMC",
                "Commerce Cloud",
                "Other",
                "Zoho one",
                "Power bi",
                "Zoho Analytics",
                "Drupal"
            ],
            "style": {
                "Zoho CRM": null,
                "Zoho Desk": null,
                "Zoho Creator": null,
                "Hubspot": null,
                "Zoho website": null,
                "Odoo": null,
                "Salesforce": null,
                "Asp.net": null,
                "Asp.net Core": null,
                "Laravel": null,
                "Wordpress": null,
                "Mobile App": null,
                "Shopify": null,
                "Magento": null,
                "Woocomerce": null,
                "SFMC": null,
                "Commerce Cloud": null,
                "Other": null,
                "Zoho one": null,
                "Power bi": null,
                "Zoho Analytics": null,
                "Drupal": null
            },
            "default": "Other",
            "isCustom": true
        },
        "addedToDocument": {
            "notNull": true,
            "type": "bool",
            "audited": true,
            "isCustom": true
        }
    },
    "links": {
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "assignedUser": {
            "type": "belongsTo",
            "entity": "User"
        },
        "teams": {
            "type": "hasMany",
            "entity": "Team",
            "relationName": "entityTeam",
            "layoutRelationshipsDisabled": true
        }
    },
    "collection": {
        "orderBy": "createdAt",
        "order": "desc"
    },
    "indexes": {
        "name": {
            "columns": [
                "name",
                "deleted"
            ]
        },
        "assignedUser": {
            "columns": [
                "assignedUserId",
                "deleted"
            ]
        },
        "createdAt": {
            "columns": [
                "createdAt"
            ]
        },
        "createdAtId": {
            "unique": true,
            "columns": [
                "createdAt",
                "id"
            ]
        }
    }
}