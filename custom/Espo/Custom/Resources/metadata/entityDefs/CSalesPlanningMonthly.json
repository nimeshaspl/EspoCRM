        "plannedLeads": {
            "type": "int",
            "required": true,
            "min": 1,
            "audited": true,
            "tooltip": true,
            "isCustom": true
        },
        "plannedDeals": {
            "type": "int",
            "required": true,
            "min": 1,
            "audited": true,
            "tooltip": true,
            "isCustom": true
