            "layoutRelationshipsDisabled": true
        },
        "salesPlanning": {
            "type": "belongsTo",
            "foreign": "salesPlanningMonthlies",
            "entity": "CSalesPlanning",
            "audited": true,
            "isCustom": true
        },
        "dataMasters": {
            "type": "hasMany",
            "relationName": "cSalesPlanningMonthlyDataMaster",
            "foreign": "salesPlanningMonthlies",
            "entity": "CDataMaster",
            "audited": false,
            "isCustom": true
        },
        "opportunities": {
            "type": "hasMany",
            "relationName": "cSalesPlanningMonthlyOpportunity",
            "foreign": "cSalesPlanningMonthlies",
            "entity": "Opportunity",
            "audited": false,
            "isCustom": true
        },
        "contacts": {
            "type": "hasMany",
            "relationName": "cSalesPlanningMonthlyContact",
            "foreign": "cSalesPlanningMonthlies",
            "entity": "Contact",
            "audited": false,
            "isCustom": true
        }
    },
    "collection": {
