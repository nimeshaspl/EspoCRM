                "Pharma",
                "Education",
                "Tech Event"
            ],
            "style": {
                "IT & Technology": null,
                "Professional Services": null,
                "Building & Construction": null,
                "Electronics": null,
                "Business Services": null,
                "Banking & Finance": null,
                "Security & Defence": null,
                "HeathCare": null,
                "Industrial": null,
                "Travel and Tourism": null,
                "Credit repair": null,
                "Data Analytics": null,
                "AI/ML": null,
                "Salesforce": null,
                "Microsoft": null,
