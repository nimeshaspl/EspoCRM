{
    "fields": {
        "name": {
            "type": "varchar",
            "required": true,
            "pattern": "$noBadCharacters",
            "options": []
        },
        "description": {
            "type": "text"
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true
        },
        "createdBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "assignedUser": {
            "type": "link",
            "required": false,
            "view": "views/fields/assigned-user"
        },
        "teams": {
            "type": "linkMultiple",
            "view": "views/fields/teams"
        },
        "fromDate": {
            "notNull": false,
            "type": "date",
            "required": true,
            "default": "javascript: return this.dateTime.getToday();",
            "tooltip": true,
            "isCustom": true
        },
        "endDate": {
            "notNull": false,
            "type": "date",
            "default": "javascript: return this.dateTime.getDateShiftedFromToday(1, 'days');",
            "after": "fromDate",
            "isCustom": true
        },
        "amount": {
            "type": "currency",
            "onlyDefaultCurrency": true,
            "min": 1,
            "tooltip": true,
            "isCustom": true
        },
        "targetType": {
            "type": "enum",
            "options": [
                "Lead Generation",
                "Revenue Generation",
                "Contact Creation",
                "New Client"
            ],
            "style": {
                "Lead Generation": null,
                "Revenue Generation": null,
                "Contact Creation": null,
                "New Client": null
            },
            "default": "Lead Generation",
            "isSorted": true,
            "displayAsLabel": true,
            "tooltip": true,
            "isCustom": true
        },
        "targetCount": {
            "type": "int",
            "min": 1,
            "tooltip": true,
            "isCustom": true
        },
        "leadCount": {
            "type": "int",
            "tooltip": true,
            "isCustom": true
        },
        "newClientTarget": {
            "type": "int",
            "tooltip": true,
            "isCustom": true
        }
    },
    "links": {
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "assignedUser": {
            "type": "belongsTo",
            "entity": "User"
        },
        "teams": {
            "type": "hasMany",
            "entity": "Team",
            "relationName": "entityTeam",
            "layoutRelationshipsDisabled": true
        }
    },
    "collection": {
        "orderBy": "createdAt",
        "order": "desc",
        "textFilterFields": [
            "name"
        ],
        "fullTextSearch": false,
        "countDisabled": false
    },
    "indexes": {
        "name": {
            "columns": [
                "name",
                "deleted"
            ]
        },
        "assignedUser": {
            "columns": [
                "assignedUserId",
                "deleted"
            ]
        },
        "createdAt": {
            "columns": [
                "createdAt"
            ]
        },
        "createdAtId": {
            "unique": true,
            "columns": [
                "createdAt",
                "id"
            ]
        }
    },
    "optimisticConcurrencyControl": false
}