            "isCustom": true
        },
        "hRAGross": {
            "notNull": false,
            "type": "float",
            "audited": true,
            "inlineEditDisabled": true,
            "isCustom": true
        },
        "isPFEnable": {
            "notNull": true,
            "type": "bool",
            "isCustom": true
