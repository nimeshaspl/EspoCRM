{
    "fields": {
        "name": {
            "type": "varchar",
            "required": false,
            "pattern": "$noBadCharacters",
            "options": []
        },
        "description": {
            "type": "text"
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true
        },
        "createdBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "assignedUser": {
            "type": "link",
            "required": false,
            "view": "views/fields/assigned-user"
        },
        "teams": {
            "type": "linkMultiple",
            "view": "views/fields/teams"
        },
        "employee": {
            "type": "link"
        },
        "addressType": {
            "type": "enum",
            "options": [
                "Permanent Address",
                "Current Address"
            ],
            "style": {
                "Permanent Address": null,
                "Current Address": null
            },
            "maxLength": 100,
            "isCustom": true,
            "default": "Permanent Address"
        },
        "address": {
            "type": "text",
            "rowsMin": 2,
            "cutHeight": 200,
            "isCustom": true
        },
        "city": {
            "type": "link",
            "view": "custom:views/employee-address/fields/city"
        },
        "state": {
            "type": "link",
            "view": "custom:views/employee-address/fields/state"
        },
        "country": {
            "type": "link"
        }
    },
    "links": {
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "assignedUser": {
            "type": "belongsTo",
            "entity": "User"
        },
        "teams": {
            "type": "hasMany",
            "entity": "Team",
            "relationName": "entityTeam",
            "layoutRelationshipsDisabled": true
        },
        "bankses": {
            "type": "hasMany",
            "foreign": "employeeAddress",
            "entity": "CBanks",
            "audited": false,
            "isCustom": true
        },
        "employee": {
            "type": "belongsTo",
            "foreign": "employeeAddresses",
            "entity": "CEmployee",
            "audited": false,
            "isCustom": true
        },
        "city": {
            "type": "belongsTo",
            "foreign": "employeeAddresses",
            "entity": "CCity",
            "audited": false,
            "isCustom": true
        },
        "state": {
            "type": "belongsTo",
            "foreign": "employeeAddresses",
            "entity": "CState",
            "audited": false,
            "isCustom": true
        },
        "country": {
            "type": "belongsTo",
            "foreign": "employeeAddresses",
            "entity": "CCountry",
            "audited": false,
            "isCustom": true
        }
    },
    "collection": {
        "orderBy": "createdAt",
        "order": "desc"
    },
    "indexes": {
        "name": {
            "columns": [
                "name",
                "deleted"
            ]
        },
        "assignedUser": {
            "columns": [
                "assignedUserId",
                "deleted"
            ]
        },
        "createdAt": {
            "columns": [
                "createdAt"
            ]
        },
        "createdAtId": {
            "unique": true,
            "columns": [
                "createdAt",
                "id"
            ]
        }
    }
}