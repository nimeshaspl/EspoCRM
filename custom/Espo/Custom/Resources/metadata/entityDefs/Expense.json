{
    "fields": {
        "name": {
            "type": "varchar",
            "required": true,
            "pattern": "$noBadCharacters",
            "options": []
        },
        "description": {
            "type": "text"
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true
        },
        "createdBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "assignedUser": {
            "type": "link",
            "required": false,
            "view": "views/fields/assigned-user"
        },
        "teams": {
            "type": "linkMultiple",
            "view": "views/fields/teams"
        },
        "expenseBillAttachement": {
            "type": "file",
            "accept": [
                "image/*",
                ".pdf",
                ".docx",
                ".xlsx",
                ".pptx",
                ".ppt",
                ".doc",
                ".xls",
                ".csv"
            ],
            "sourceList": [
                "Document"
            ],
            "isCustom": true
        },
        "amount": {
            "notNull": false,
            "type": "float",
            "required": true,
            "min": null,
            "decimalPlaces": 2,
            "audited": true,
            "isCustom": true
        },
        "vendorName": {
            "type": "text",
            "required": true,
            "rowsMin": 2,
            "cutHeight": 200,
            "audited": true,
            "isCustom": true
        },
        "otherDescription": {
            "type": "wysiwyg",
            "audited": true,
            "isCustom": true
        },
        "paidBy": {
            "type": "enum",
            "options": [
                "Petty Cash",
                "Personal",
                "Direct",
                "Pending"
            ],
            "style": {
                "Petty Cash": null,
                "Personal": null,
                "Direct": null,
                "Pending": null
            },
            "default": "Petty Cash",
            "isCustom": true
        },
        "expenseDate": {
            "notNull": false,
            "type": "date",
            "required": true,
            "audited": true,
            "isCustom": true
        },
        "category": {
            "type": "enum",
            "required": true,
            "options": [
                "Milk",
                "Water",
                "Grocery",
                "Employee Refreshment",
                "Hardware Repair",
                "Hardware Purchase",
                "Stationary",
                "Travelling",
                "Fuel",
                "Other"
            ],
            "style": {
                "Milk": null,
                "Water": null,
                "Grocery": null,
                "Employee Refreshment": null,
                "Hardware Repair": null,
                "Hardware Purchase": null,
                "Stationary": null,
                "Travelling": null,
                "Fuel": null,
                "Other": null
            },
            "default": "Other",
            "isSorted": true,
            "audited": true,
            "isCustom": true
        }
    },
    "links": {
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "assignedUser": {
            "type": "belongsTo",
            "entity": "User"
        },
        "teams": {
            "type": "hasMany",
            "entity": "Team",
            "relationName": "entityTeam",
            "layoutRelationshipsDisabled": true
        },
        "expenseBillAttachement": {
            "type": "belongsTo",
            "entity": "Attachment",
            "skipOrmDefs": true,
            "utility": true
        }
    },
    "collection": {
        "orderBy": "createdAt",
        "order": "desc",
        "textFilterFields": [
            "name"
        ],
        "fullTextSearch": true,
        "countDisabled": false
    },
    "indexes": {
        "name": {
            "columns": [
                "name",
                "deleted"
            ]
        },
        "assignedUser": {
            "columns": [
                "assignedUserId",
                "deleted"
            ]
        },
        "createdAt": {
            "columns": [
                "createdAt"
            ]
        },
        "createdAtId": {
            "unique": true,
            "columns": [
                "createdAt",
                "id"
            ]
        }
    },
    "optimisticConcurrencyControl": false
}