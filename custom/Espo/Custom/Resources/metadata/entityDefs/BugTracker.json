{
    "fields": {
        "name": {
            "type": "varchar",
            "required": true,
            "pattern": "$noBadCharacters",
            "options": []
        },
        "description": {
            "type": "text"
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true
        },
        "createdBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "assignedUser": {
            "type": "link",
            "required": false,
            "view": "views/fields/assigned-user"
        },
        "teams": {
            "type": "linkMultiple",
            "view": "views/fields/teams",
            "readOnly": true
        },
        "status": {
            "type": "enum",
            "required": true,
            "options": [
                "Pending",
                "In Progress",
                "QA",
                "UAT",
                "Completed"
            ],
            "style": {
                "Pending": "danger",
                "In Progress": "warning",
                "QA": "primary",
                "UAT": "info",
                "Completed": "success"
            },
            "default": "Pending",
            "isCustom": true
        },
        "bugBy": {
            "type": "enum",
            "options": [
                "Client",
                "QA",
                "PM"
            ],
            "style": {
                "Client": null,
                "QA": null,
                "PM": null
            },
            "default": "Client",
            "isCustom": true
        },
        "files": {
            "type": "file",
            "maxFileSize": 10,
            "sourceList": [],
            "accept": [],
            "isCustom": true
        },
        "priority": {
            "type": "enum",
            "options": [
                "Low",
                "Medium",
                "High"
            ],
            "style": {
                "Low": null,
                "Medium": null,
                "High": null
            },
            "default": "Low",
            "isCustom": true
        },
        "totalHours": {
            "type": "int",
            "readOnly": true,
            "isCustom": true
        },
        "projectTask": {
            "type": "link",
            "required": true
        },
        "timesheets": {
            "type": "linkMultiple",
            "layoutDetailDisabled": false,
            "layoutMassUpdateDisabled": false,
            "layoutListDisabled": false,
            "noLoad": false,
            "importDisabled": false,
            "exportDisabled": false,
            "customizationDisabled": true,
            "isCustom": true
        },
        "account": {
            "type": "link",
            "readOnly": true
        },
        "project": {
            "type": "link",
            "readOnly": true
        },
        "cRHour": {
            "notNull": false,
            "type": "float",
            "decimalPlaces": 2,
            "audited": true,
            "isCustom": true
        },
        "invoiceNo": {
            "type": "varchar",
            "maxLength": 150,
            "options": [],
            "isCustom": true,
            "audited": true
        },
        "testingData": {
            "type": "wysiwyg",
            "isCustom": true
        },
        "bugId": {
            "type": "varchar",
            "maxLength": 150,
            "options": [],
            "audited": true,
            "readOnly": true,
            "inlineEditDisabled": true,
            "isCustom": true
        },
        "totalCost": {
            "notNull": false,
            "type": "float",
            "readOnly": true,
            "isCustom": true
        },
        "totalBugHours": {
            "notNull": false,
            "type": "float",
            "readOnly": true,
            "isCustom": true
        }
    },
    "links": {
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "assignedUser": {
            "type": "belongsTo",
            "entity": "User"
        },
        "teams": {
            "type": "hasMany",
            "entity": "Team",
            "relationName": "entityTeam",
            "layoutRelationshipsDisabled": true
        },
        "files": {
            "type": "belongsTo",
            "entity": "Attachment",
            "skipOrmDefs": true,
            "utility": true
        },
        "projectTask": {
            "type": "belongsTo",
            "foreign": "bugTrackers",
            "entity": "ProjectTask",
            "audited": true,
            "isCustom": true
        },
        "timesheets": {
            "type": "hasMany",
            "foreign": "bugTracker",
            "entity": "Timesheet",
            "audited": false,
            "isCustom": true
        },
        "account": {
            "type": "belongsTo",
            "foreign": "bugTrackers",
            "entity": "Account",
            "audited": false,
            "isCustom": true
        },
        "project": {
            "type": "belongsTo",
            "foreign": "bugTrackers",
            "entity": "Project",
            "audited": true,
            "isCustom": true
        }
    },
    "collection": {
        "orderBy": "createdAt",
        "order": "desc",
        "textFilterFields": [
            "name",
            "description",
            "bugId"
        ],
        "fullTextSearch": true,
        "countDisabled": false
    },
    "indexes": {
        "name": {
            "columns": [
                "name",
                "deleted"
            ]
        },
        "assignedUser": {
            "columns": [
                "assignedUserId",
                "deleted"
            ]
        },
        "createdAt": {
            "columns": [
                "createdAt"
            ]
        },
        "createdAtId": {
            "unique": true,
            "columns": [
                "createdAt",
                "id"
            ]
        }
    },
    "optimisticConcurrencyControl": false
}