{
    "fields": {
        "name": {
            "type": "varchar",
            "required": true,
            "pattern": "$noBadCharacters",
            "options": []
        },
        "description": {
            "type": "text"
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true
        },
        "createdBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "assignedUser": {
            "type": "link",
            "required": false,
            "view": "views/fields/assigned-user"
        },
        "teams": {
            "type": "linkMultiple",
            "view": "views/fields/teams",
            "required": false,
            "readOnly": true
        },
        "startDate": {
            "notNull": false,
            "type": "date",
            "required": true,
            "audited": true,
            "isCustom": true
        },
        "endDate": {
            "notNull": false,
            "type": "date",
            "required": true,
            "audited": true,
            "isCustom": true
        },
        "plannedHours": {
            "notNull": false,
            "type": "float",
            "required": false,
            "min": 0,
            "decimalPlaces": 2,
            "isCustom": true,
            "default": 1
        },
        "actualHours": {
            "notNull": false,
            "type": "float",
            "decimalPlaces": 2,
            "readOnly": true,
            "isCustom": true
        },
        "document": {
            "type": "file",
            "maxFileSize": 10,
            "accept": [
                "image/*",
                "video/*",
                ".zip",
                ".pdf",
                ".docx",
                ".xlsx",
                ".pptx",
                ".doc",
                ".xls",
                ".ppt",
                ".csv"
            ],
            "sourceList": [],
            "isCustom": true
        },
        "status": {
            "type": "enum",
            "required": true,
            "options": [
                "Not Started",
                "In Progress",
                "QA",
                "UAT",
                "Completed",
                "On Hold"
            ],
            "style": {
                "Not Started": null,
                "In Progress": "warning",
                "QA": "primary",
                "UAT": "info",
                "Completed": "success",
                "On Hold": "danger"
            },
            "default": "Not Started",
            "isCustom": true,
            "displayAsLabel": true
        },
        "milestone": {
            "type": "link"
        },
        "project": {
            "type": "link",
            "required": true
        },
        "totalBug": {
            "type": "int",
            "readOnly": true,
            "isCustom": true
        },
        "pendingBug": {
            "type": "int",
            "readOnly": true,
            "isCustom": true
        },
        "resolvedBug": {
            "type": "int",
            "readOnly": true,
            "isCustom": true
        },
        "timesheets": {
            "type": "linkMultiple",
            "layoutDetailDisabled": false,
            "layoutMassUpdateDisabled": false,
            "layoutListDisabled": false,
            "noLoad": false,
            "importDisabled": false,
            "exportDisabled": false,
            "customizationDisabled": true,
            "isCustom": true
        },
        "bugTrackers": {
            "type": "linkMultiple",
            "layoutDetailDisabled": false,
            "layoutMassUpdateDisabled": false,
            "layoutListDisabled": false,
            "noLoad": false,
            "importDisabled": false,
            "exportDisabled": false,
            "customizationDisabled": true,
            "isCustom": true
        },
        "testCaseses": {
            "type": "linkMultiple",
            "layoutDetailDisabled": false,
            "layoutMassUpdateDisabled": false,
            "layoutListDisabled": false,
            "noLoad": false,
            "importDisabled": false,
            "exportDisabled": false,
            "customizationDisabled": true,
            "isCustom": true
        },
        "account": {
            "type": "link",
            "readOnly": true
        },
        "cRHour": {
            "notNull": false,
            "type": "float",
            "audited": true,
            "isCustom": true
        },
        "invoiceNo": {
            "type": "text",
            "rowsMin": 2,
            "cutHeight": 200,
            "isCustom": true
        },
        "taskID": {
            "type": "varchar",
            "maxLength": 150,
            "readOnly": true,
            "audited": true,
            "inlineEditDisabled": true,
            "options": [],
            "isCustom": true
        },
        "totalCost": {
            "notNull": false,
            "type": "float",
            "readOnly": true,
            "isCustom": true,
            "decimalPlaces": 2
        }
    },
    "links": {
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "assignedUser": {
            "type": "belongsTo",
            "entity": "User"
        },
        "teams": {
            "type": "hasMany",
            "entity": "Team",
            "relationName": "entityTeam",
            "layoutRelationshipsDisabled": true
        },
        "document": {
            "type": "belongsTo",
            "entity": "Attachment",
            "skipOrmDefs": true,
            "utility": true
        },
        "milestone": {
            "type": "belongsTo",
            "foreign": "projectTasks",
            "entity": "Milestone",
            "audited": true,
            "isCustom": true
        },
        "project": {
            "type": "belongsTo",
            "foreign": "projectTasks",
            "entity": "Project",
            "audited": true,
            "isCustom": true
        },
        "timesheets": {
            "type": "hasMany",
            "foreign": "projectTask",
            "entity": "Timesheet",
            "audited": false,
            "isCustom": true
        },
        "bugTrackers": {
            "type": "hasMany",
            "foreign": "projectTask",
            "entity": "BugTracker",
            "audited": false,
            "isCustom": true
        },
        "testCaseses": {
            "type": "hasMany",
            "foreign": "projectTask",
            "entity": "TestCases",
            "audited": false,
            "isCustom": true
        },
        "account": {
            "type": "belongsTo",
            "foreign": "projectTasks",
            "entity": "Account",
            "audited": false,
            "isCustom": true
        }
    },
    "collection": {
        "orderBy": "startDate",
        "order": "asc",
        "textFilterFields": [
            "name",
            "description",
            "taskID"
        ],
        "fullTextSearch": true,
        "countDisabled": false
    },
    "indexes": {
        "name": {
            "columns": [
                "name",
                "deleted"
            ]
        },
        "assignedUser": {
            "columns": [
                "assignedUserId",
                "deleted"
            ]
        },
        "createdAt": {
            "columns": [
                "createdAt"
            ]
        },
        "createdAtId": {
            "unique": true,
            "columns": [
                "createdAt",
                "id"
            ]
        }
    },
    "optimisticConcurrencyControl": false
}