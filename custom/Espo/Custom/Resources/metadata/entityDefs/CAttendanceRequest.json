{
    "fields": {
        "name": {
            "type": "varchar",
            "required": true,
            "pattern": "$noBadCharacters"
        },
        "description": {
            "type": "text"
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true
        },
        "createdBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "assignedUser": {
            "type": "link",
            "required": false,
            "view": "views/fields/assigned-user"
        },
        "teams": {
            "type": "linkMultiple",
            "view": "views/fields/teams"
        },
        "clockIn": {
            "notNull": false,
            "type": "datetime",
            "minuteStep": 30,
            "isCustom": true
        },
        "clockOut": {
            "notNull": false,
            "type": "datetime",
            "minuteStep": 30,
            "isCustom": true
        },
        "reason": {
            "type": "text",
            "rowsMin": 2,
            "cutHeight": 200,
            "isCustom": true
        },
        "employee": {
            "type": "link"
        },
        "date": {
            "notNull": false,
            "type": "date",
            "isCustom": true,
            "required": true,
            "audited": true,
            "readOnlyAfterCreate": true,
            "inlineEditDisabled": true
        },
        "status": {
            "type": "enum",
            "options": [
                "Pending",
                "Approved",
                "Rejected"
            ],
            "style": {
                "Pending": null,
                "Approved": null,
                "Rejected": null
            },
            "default": "Pending",
            "maxLength": 100,
            "isCustom": true,
            "required": true,
            "audited": true,
            "inlineEditDisabled": true
        },
        "systemClockIn": {
            "notNull": false,
            "type": "datetime",
            "audited": true,
            "readOnlyAfterCreate": true,
            "inlineEditDisabled": true,
            "minuteStep": 30,
            "isCustom": true
        },
        "systemClockOut": {
            "notNull": false,
            "type": "datetime",
            "audited": true,
            "readOnlyAfterCreate": true,
            "inlineEditDisabled": true,
            "minuteStep": 30,
            "isCustom": true
        }
    },
    "links": {
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "assignedUser": {
            "type": "belongsTo",
            "entity": "User"
        },
        "teams": {
            "type": "hasMany",
            "entity": "Team",
            "relationName": "entityTeam",
            "layoutRelationshipsDisabled": true
        },
        "employee": {
            "type": "belongsTo",
            "foreign": "attendanceRequests",
            "entity": "CEmployee",
            "audited": false,
            "isCustom": true
        }
    },
    "collection": {
        "orderBy": "createdAt",
        "order": "desc",
        "textFilterFields": [
            "name"
        ],
        "fullTextSearch": false,
        "countDisabled": false
    },
    "indexes": {
        "name": {
            "columns": [
                "name",
                "deleted"
            ]
        },
        "assignedUser": {
            "columns": [
                "assignedUserId",
                "deleted"
            ]
        },
        "createdAt": {
            "columns": [
                "createdAt"
            ]
        },
        "createdAtId": {
            "unique": true,
            "columns": [
                "createdAt",
                "id"
            ]
        }
    },
    "optimisticConcurrencyControl": false
}