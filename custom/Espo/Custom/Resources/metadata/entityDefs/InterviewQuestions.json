{
    "fields": {
        "name": {
            "type": "varchar",
            "required": true,
            "pattern": "$noBadCharacters",
            "options": []
        },
        "description": {
            "type": "text"
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true
        },
        "createdBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "assignedUser": {
            "type": "link",
            "required": false,
            "view": "views/fields/assigned-user"
        },
        "teams": {
            "type": "linkMultiple",
            "view": "views/fields/teams"
        },
        "technology": {
            "type": "multiEnum",
            "storeArrayValues": true,
            "default": [],
            "options": [
                "Asp.net",
                "Asp.net Core",
                "Asp.net MVC",
                "SQL Server",
                "Mongo DB",
                "Linq",
                "Salesforce Salescloud",
                "Saleforce LWC",
                "Salesforce CPQ",
                "Salesforce APEX",
                "Salesforce SOQL",
                "PHP",
                "PHP Laravel",
                "PHP Codignator"
            ],
            "style": {
                "Asp.net": null,
                "Asp.net Core": null,
                "Asp.net MVC": null,
                "SQL Server": null,
                "Mongo DB": null,
                "Linq": null,
                "Salesforce Salescloud": null,
                "Saleforce LWC": null,
                "Salesforce CPQ": null,
                "Salesforce APEX": null,
                "Salesforce SOQL": null,
                "PHP": null,
                "PHP Laravel": null,
                "PHP Codignator": null
            },
            "isCustom": true
        },
        "taskDetails": {
            "type": "image",
            "previewSize": "small",
            "isCustom": true
        },
        "expertise": {
            "type": "enum",
            "options": [
                "Basic",
                "Intermediate",
                "Expert"
            ],
            "style": {
                "Basic": null,
                "Intermediate": null,
                "Expert": null
            },
            "default": "Basic",
            "isCustom": true
        }
    },
    "links": {
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "assignedUser": {
            "type": "belongsTo",
            "entity": "User"
        },
        "teams": {
            "type": "hasMany",
            "entity": "Team",
            "relationName": "entityTeam",
            "layoutRelationshipsDisabled": true
        },
        "taskDetails": {
            "type": "belongsTo",
            "entity": "Attachment",
            "skipOrmDefs": true,
            "utility": true
        }
    },
    "collection": {
        "orderBy": "createdAt",
        "order": "desc"
    },
    "indexes": {
        "name": {
            "columns": [
                "name",
                "deleted"
            ]
        },
        "assignedUser": {
            "columns": [
                "assignedUserId",
                "deleted"
            ]
        },
        "createdAt": {
            "columns": [
                "createdAt"
            ]
        },
        "createdAtId": {
            "unique": true,
            "columns": [
                "createdAt",
                "id"
            ]
        }
    }
}