{
    "fields": {
        "name": {
            "type": "varchar",
            "required": false,
            "pattern": "$noBadCharacters",
            "options": []
        },
        "description": {
            "type": "text"
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true
        },
        "createdBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "assignedUser": {
            "type": "link",
            "required": false,
            "view": "views/fields/assigned-user"
        },
        "teams": {
            "type": "linkMultiple",
            "view": "views/fields/teams"
        },
        "type": {
            "type": "enum",
            "options": [
                "Loan for Home",
                "Car Loan",
                "Personal Loan"
            ],
            "style": {
                "Loan for Home": null,
                "Car Loan": null,
                "Personal Loan": null
            },
            "default": "Loan for Home",
            "maxLength": 100,
            "isCustom": true,
            "readOnlyAfterCreate": true
        },
        "loanAmount": {
            "type": "currency",
            "isCustom": true
        },
        "amountPending": {
            "type": "currency",
            "isCustom": true,
            "readOnly": false
        },
        "interest": {
            "type": "currency",
            "isCustom": true,
            "readOnlyAfterCreate": false
        },
        "totalRepayableAmount": {
            "type": "currency",
            "isCustom": true,
            "readOnly": false
        },
        "amountRepaid": {
            "type": "currency",
            "isCustom": true,
            "readOnly": false
        },
        "recoveryStartMonth": {
            "notNull": false,
            "type": "date",
            "isCustom": true,
            "readOnlyAfterCreate": true
        },
        "recoveryEndMonth": {
            "notNull": false,
            "type": "date",
            "isCustom": true,
            "readOnly": true
        },
        "numberOfInstallments": {
            "type": "int",
            "isCustom": true
        },
        "currentEMI": {
            "type": "currency",
            "isCustom": true,
            "readOnly": false
        },
        "employee": {
            "type": "link"
        },
        "loanCreditedOn": {
            "notNull": false,
            "type": "date",
            "isCustom": true,
            "default": "javascript: return this.dateTime.getToday();",
            "readOnlyAfterCreate": false
        },
        "interestRate": {
            "notNull": false,
            "type": "float",
            "isCustom": true
        }
    },
    "links": {
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "assignedUser": {
            "type": "belongsTo",
            "entity": "User"
        },
        "teams": {
            "type": "hasMany",
            "entity": "Team",
            "relationName": "entityTeam",
            "layoutRelationshipsDisabled": true
        },
        "employee": {
            "type": "belongsTo",
            "foreign": "loans",
            "entity": "CEmployee",
            "audited": false,
            "isCustom": true
        },
        "transactionTimelines": {
            "type": "hasMany",
            "foreign": "loan",
            "entity": "CTransactionTimeline",
            "audited": false,
            "isCustom": true
        },
        "payslips": {
            "type": "hasMany",
            "foreign": "loan",
            "entity": "CPayslip",
            "audited": false,
            "isCustom": true
        }
    },
    "collection": {
        "orderBy": "createdAt",
        "order": "desc",
        "textFilterFields": [
            "name",
            "numberOfInstallments"
        ],
        "fullTextSearch": false,
        "countDisabled": false
    },
    "indexes": {
        "name": {
            "columns": [
                "name",
                "deleted"
            ]
        },
        "assignedUser": {
            "columns": [
                "assignedUserId",
                "deleted"
            ]
        },
        "createdAt": {
            "columns": [
                "createdAt"
            ]
        }
    },
    "optimisticConcurrencyControl": false
}