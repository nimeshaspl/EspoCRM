{
    "fields": {
        "name": {
            "type": "varchar",
            "required": false,
            "pattern": "$noBadCharacters",
            "options": []
        },
        "description": {
            "type": "text"
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true
        },
        "createdBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "assignedUser": {
            "type": "link",
            "required": false,
            "view": "views/fields/assigned-user"
        },
        "teams": {
            "type": "linkMultiple",
            "view": "views/fields/teams"
        },
        "loan": {
            "type": "link"
        },
        "month": {
            "notNull": false,
            "type": "date",
            "isCustom": true
        },
        "status": {
            "type": "enum",
            "options": [
                "Credited",
                "Deducted",
                "Pending",
                "Skipped"
            ],
            "style": {
                "Credited": null,
                "Deducted": null,
                "Pending": null,
                "Skipped": null
            },
            "default": "Credited",
            "maxLength": 100,
            "isCustom": true
        },
        "amount": {
            "type": "currency",
            "isCustom": true
        },
        "isSkipped": {
            "notNull": true,
            "type": "bool",
            "isCustom": true
        },
        "isDeducted": {
            "notNull": true,
            "type": "bool",
            "isCustom": true
        },
        "installmentNo": {
            "type": "int",
            "isCustom": true
        },
        "principalPaid": {
            "type": "currency",
            "isCustom": true
        },
        "interestCharged": {
            "type": "currency",
            "isCustom": true
        },
        "balance": {
            "type": "currency",
            "isCustom": true
        }
    },
    "links": {
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "assignedUser": {
            "type": "belongsTo",
            "entity": "User"
        },
        "teams": {
            "type": "hasMany",
            "entity": "Team",
            "relationName": "entityTeam",
            "layoutRelationshipsDisabled": true
        },
        "loan": {
            "type": "belongsTo",
            "foreign": "transactionTimelines",
            "entity": "CLoan",
            "audited": false,
            "isCustom": true
        }
    },
    "collection": {
        "orderBy": "createdAt",
        "order": "desc"
    },
    "indexes": {
        "name": {
            "columns": [
                "name",
                "deleted"
            ]
        },
        "assignedUser": {
            "columns": [
                "assignedUserId",
                "deleted"
            ]
        },
        "createdAt": {
            "columns": [
                "createdAt"
            ]
        },
        "createdAtId": {
            "unique": true,
            "columns": [
                "createdAt",
                "id"
            ]
        }
    }
}