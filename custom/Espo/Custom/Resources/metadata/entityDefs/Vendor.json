{
    "fields": {
        "name": {
            "type": "varchar",
            "required": true,
            "pattern": "$noBadCharacters",
            "options": []
        },
        "description": {
            "type": "text"
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true
        },
        "createdBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "assignedUser": {
            "type": "link",
            "required": false,
            "view": "views/fields/assigned-user"
        },
        "teams": {
            "type": "linkMultiple",
            "view": "views/fields/teams"
        },
        "vendorAddress": {
            "type": "address",
            "isCustom": true
        },
        "technology": {
            "type": "multiEnum",
            "storeArrayValues": true,
            "options": [
                "Salesforce Salescloud",
                "Marketing Cloud",
                "Zoho",
                "Hubspot",
                "CRM",
                "Service cloud",
                "Microsoft",
                "Open source",
                "Node js"
            ],
            "style": {
                "Salesforce Salescloud": null,
                "Marketing Cloud": null,
                "Zoho": null,
                "Hubspot": null,
                "CRM": null,
                "Service cloud": null,
                "Microsoft": null,
                "Open source": null,
                "Node js": null
            },
            "isCustom": true,
            "default": []
        },
        "cVendorResourceses": {
            "type": "linkMultiple",
            "layoutDetailDisabled": true,
            "layoutMassUpdateDisabled": true,
            "layoutListDisabled": true,
            "noLoad": true,
            "importDisabled": true,
            "exportDisabled": true,
            "customizationDisabled": true,
            "isCustom": true
        },
        "type": {
            "type": "enum",
            "options": [
                "Individual",
                "Company"
            ],
            "default": "Individual",
            "style": {
                "Individual": null,
                "Company": null
            },
            "maxLength": 100,
            "isCustom": true
        },
        "website": {
            "type": "url",
            "isCustom": true
        }
    },
    "links": {
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "assignedUser": {
            "type": "belongsTo",
            "entity": "User"
        },
        "teams": {
            "type": "hasMany",
            "entity": "Team",
            "relationName": "entityTeam",
            "layoutRelationshipsDisabled": true
        },
        "cVendorResourceses": {
            "type": "hasMany",
            "foreign": "vendor",
            "entity": "CVendorResources",
            "audited": false,
            "isCustom": true
        }
    },
    "collection": {
        "orderBy": "createdAt",
        "order": "desc"
    },
    "indexes": {
        "name": {
            "columns": [
                "name",
                "deleted"
            ]
        },
        "assignedUser": {
            "columns": [
                "assignedUserId",
                "deleted"
            ]
        },
        "createdAt": {
            "columns": [
                "createdAt"
            ]
        },
        "createdAtId": {
            "unique": true,
            "columns": [
                "createdAt",
                "id"
            ]
        }
    }
}