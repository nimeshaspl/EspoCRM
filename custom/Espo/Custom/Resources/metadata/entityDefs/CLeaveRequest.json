{
    "fields": {
        "name": {
            "type": "varchar",
            "required": true,
            "pattern": "$noBadCharacters"
        },
        "description": {
            "type": "text"
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true
        },
        "createdBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "assignedUser": {
            "type": "link",
            "required": false,
            "view": "views/fields/assigned-user"
        },
        "teams": {
            "type": "linkMultiple",
            "view": "views/fields/teams"
        },
        "user": {
            "type": "link"
        },
        "leaveType": {
            "type": "enum",
            "options": [
                "Paid",
                "Unpaid"
            ],
            "style": {
                "Paid": null,
                "Unpaid": null
            },
            "default": "Paid",
            "maxLength": 100,
            "isCustom": true
        },
        "startDate": {
            "notNull": false,
            "type": "date",
            "isCustom": true
        },
        "endDate": {
            "notNull": false,
            "type": "date",
            "isCustom": true
        },
        "days": {
            "notNull": false,
            "type": "float",
            "isCustom": true
        },
        "reason": {
            "type": "text",
            "rowsMin": 2,
            "cutHeight": 200,
            "isCustom": true
        },
        "status": {
            "type": "enum",
            "options": [
                "Pending",
                "Approved",
                "Rejected",
                "Cancelled"
            ],
            "style": {
                "Pending": null,
                "Approved": null,
                "Rejected": null,
                "Cancelled": null
            },
            "default": "Pending",
            "maxLength": 100,
            "isCustom": true,
            "required": true,
            "audited": true,
            "inlineEditDisabled": true
        },
        "appliedDate": {
            "notNull": false,
            "type": "date",
            "isCustom": true,
            "default": "javascript: return this.dateTime.getToday();"
        },
        "appliedFor": {
            "type": "enum",
            "options": [
                "Single day",
                "Multiple days"
            ],
            "style": {
                "Single day": null,
                "Multiple days": null
            },
            "default": "Single day",
            "maxLength": 100,
            "isCustom": true
        },
        "approvedBy": {
            "readOnly": true,
            "type": "foreign",
            "link": "user",
            "field": "userName",
            "view": "views/fields/foreign-varchar",
            "isCustom": true
        },
        "dayMode": {
            "type": "enum",
            "options": [
                "Full",
                "First Half",
                "Second Half"
            ],
            "style": {
                "Full": null,
                "First Half": null,
                "Second Half": null
            },
            "default": "Full",
            "maxLength": 100,
            "isCustom": true
        },
        "employee": {
            "type": "link"
        },
        "fiscalYear": {
            "type": "varchar",
            "required": false,
            "maxLength": 100,
            "audited": true,
            "readOnlyAfterCreate": true,
            "inlineEditDisabled": true,
            "options": [],
            "isCustom": true
        }
    },
    "links": {
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "assignedUser": {
            "type": "belongsTo",
            "entity": "User"
        },
        "teams": {
            "type": "hasMany",
            "entity": "Team",
            "relationName": "entityTeam",
            "layoutRelationshipsDisabled": true
        },
        "user": {
            "type": "belongsTo",
            "foreign": "cLeaveRequests",
            "entity": "User",
            "audited": false,
            "isCustom": true
        },
        "users": {
            "type": "hasMany",
            "foreign": "cApprovedBy",
            "entity": "User",
            "audited": false,
            "isCustom": true
        },
        "employee": {
            "type": "belongsTo",
            "foreign": "leaveRequests",
            "entity": "CEmployee",
            "audited": false,
            "isCustom": true
        }
    },
    "collection": {
        "orderBy": "createdAt",
        "order": "desc",
        "textFilterFields": [
            "name"
        ],
        "fullTextSearch": false,
        "countDisabled": false
    },
    "indexes": {
        "name": {
            "columns": [
                "name",
                "deleted"
            ]
        },
        "assignedUser": {
            "columns": [
                "assignedUserId",
                "deleted"
            ]
        },
        "createdAt": {
            "columns": [
                "createdAt"
            ]
        },
        "createdAtId": {
            "unique": true,
            "columns": [
                "createdAt",
                "id"
            ]
        }
    },
    "optimisticConcurrencyControl": false
}