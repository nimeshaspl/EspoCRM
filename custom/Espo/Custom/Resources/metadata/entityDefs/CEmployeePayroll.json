{
    "fields": {
        "name": {
            "type": "varchar",
            "required": true,
            "pattern": "$noBadCharacters"
        },
        "description": {
            "type": "text"
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true
        },
        "createdBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "assignedUser": {
            "type": "link",
            "required": false,
            "view": "views/fields/assigned-user"
        },
        "teams": {
            "type": "linkMultiple",
            "view": "views/fields/teams"
        },
        "employee": {
            "type": "link"
        },
        "presentDays": {
            "notNull": false,
            "type": "float",
            "isCustom": true
        },
        "workingDays": {
            "notNull": false,
            "type": "float",
            "audited": true,
            "inlineEditDisabled": true,
            "isCustom": true
        },
        "leaveDays": {
            "notNull": false,
            "type": "float",
            "isCustom": true
        },
        "grossSalary": {
            "type": "currency",
            "isCustom": true
        },
        "loanDeduction": {
            "type": "currency",
            "isCustom": true
        },
        "advanceDeduction": {
            "type": "currency",
            "isCustom": true
        },
        "pFAmount": {
            "type": "currency",
            "isCustom": true
        },
        "esicAmount": {
            "type": "currency",
            "isCustom": true
        },
        "professionalTax": {
            "type": "currency",
            "isCustom": true
        },
        "tdsAmount": {
            "type": "currency",
            "isCustom": true
        },
        "totalDeductions": {
            "type": "currency",
            "isCustom": true
        },
        "netSalary": {
            "type": "currency",
            "isCustom": true
        },
        "paymentStatus": {
            "type": "enum",
            "options": [
                "Pending",
                "Processed",
                "Paid"
            ],
            "style": {
                "Pending": null,
                "Processed": null,
                "Paid": null
            },
            "default": "Pending",
            "audited": true,
            "inlineEditDisabled": true,
            "maxLength": 100,
            "isCustom": true
        },
        "paymentDate": {
            "notNull": false,
            "type": "date",
            "required": true,
            "audited": true,
            "inlineEditDisabled": true,
            "isCustom": true
        }
    },
    "links": {
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "assignedUser": {
            "type": "belongsTo",
            "entity": "User"
        },
        "teams": {
            "type": "hasMany",
            "entity": "Team",
            "relationName": "entityTeam",
            "layoutRelationshipsDisabled": true
        },
        "employee": {
            "type": "belongsTo",
            "foreign": "employeePayrolls",
            "entity": "CEmployee",
            "audited": false,
            "isCustom": true
        },
        "payrollDetailses": {
            "type": "hasMany",
            "foreign": "employeePayroll",
            "entity": "CPayrollDetails",
            "audited": false,
            "isCustom": true
        }
    },
    "collection": {
        "orderBy": "createdAt",
        "order": "desc"
    },
    "indexes": {
        "name": {
            "columns": [
                "name",
                "deleted"
            ]
        },
        "assignedUser": {
            "columns": [
                "assignedUserId",
                "deleted"
            ]
        },
        "createdAt": {
            "columns": [
                "createdAt"
            ]
        },
        "createdAtId": {
            "unique": true,
            "columns": [
                "createdAt",
                "id"
            ]
        }
    }
}