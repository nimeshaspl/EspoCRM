{
    "fields": {
        "name": {
            "type": "varchar",
            "required": false,
            "pattern": "{{employeeName}} - {{date}}",
            "readOnly": true,
            "options": []
        },
        "description": {
            "type": "text"
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true
        },
        "createdBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "assignedUser": {
            "type": "link",
            "required": false,
            "view": "views/fields/assigned-user"
        },
        "teams": {
            "type": "linkMultiple",
            "view": "views/fields/teams"
        },
        "parent": {
            "type": "linkParent",
            "entityList": [
                "CEmployee"
            ]
        },
        "date": {
            "notNull": false,
            "type": "date",
            "default": "javascript: return this.dateTime.getToday();",
            "isCustom": true,
            "required": false,
            "audited": true,
            "readOnly": false,
            "readOnlyAfterCreate": true,
            "inlineEditDisabled": true
        },
        "firstClockIn": {
            "notNull": false,
            "type": "datetime",
            "minuteStep": 30,
            "isCustom": true
        },
        "lastClockOut": {
            "notNull": false,
            "type": "datetime",
            "minuteStep": 30,
            "isCustom": true
        },
        "status": {
            "type": "enum",
            "options": [
                "Present",
                "Absent",
                "Half Day",
                "Pending",
                "Leave"
            ],
            "style": {
                "Present": null,
                "Absent": null,
                "Half Day": null,
                "Pending": null,
                "Leave": null
            },
            "default": "Present",
            "maxLength": 100,
            "isCustom": true
        },
        "notes": {
            "type": "text",
            "rowsMin": 2,
            "cutHeight": 200,
            "isCustom": true
        },
        "employee": {
            "type": "link"
        },
        "employeesName": {
            "readOnly": true,
            "type": "foreign",
            "link": "employee",
            "field": "name",
            "view": "views/fields/foreign-varchar",
            "isCustom": true
        },
        "payslip": {
            "type": "link"
        },
        "totalHours": {
            "type": "varchar",
            "maxLength": 100,
            "options": [],
            "isCustom": true
        },
        "totalWorkSeconds": {
            "type": "int",
            "isCustom": true
        },
        "backupClockIn": {
            "notNull": false,
            "type": "datetime",
            "minuteStep": 30,
            "isCustom": true,
            "audited": true,
            "inlineEditDisabled": true
        },
        "backupClockOut": {
            "notNull": false,
            "type": "datetime",
            "minuteStep": 30,
            "isCustom": true,
            "audited": true,
            "inlineEditDisabled": true
        },
        "backupStatus": {
            "type": "enum",
            "options": [
                "Present",
                "Absent",
                "Leave"
            ],
            "style": {
                "Present": null,
                "Absent": null,
                "Leave": null
            },
            "default": "Present",
            "maxLength": 100,
            "isCustom": true,
            "audited": true,
            "inlineEditDisabled": true
        }
    },
    "links": {
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "assignedUser": {
            "type": "belongsTo",
            "entity": "User"
        },
        "teams": {
            "type": "hasMany",
            "entity": "Team",
            "relationName": "entityTeam",
            "layoutRelationshipsDisabled": true
        },
        "parent": {
            "type": "belongsToParent",
            "foreign": "cAttendances",
            "isCustom": true
        },
        "attendanceHistories": {
            "type": "hasMany",
            "foreign": "attendance",
            "entity": "CAttendanceHistory",
            "audited": false,
            "isCustom": true
        },
        "employee": {
            "type": "belongsTo",
            "foreign": "attendances",
            "entity": "CEmployee",
            "audited": false,
            "isCustom": true
        },
        "payslip": {
            "type": "belongsTo",
            "foreign": "attendances",
            "entity": "CPayslip",
            "audited": false,
            "isCustom": true
        }
    },
    "collection": {
        "orderBy": "createdAt",
        "order": "desc",
        "textFilterFields": [
            "name"
        ],
        "fullTextSearch": false,
        "countDisabled": false
    },
    "indexes": {
        "name": {
            "columns": [
                "name",
                "deleted"
            ]
        },
        "assignedUser": {
            "columns": [
                "assignedUserId",
                "deleted"
            ]
        },
        "createdAt": {
            "columns": [
                "createdAt"
            ]
        },
        "createdAtId": {
            "unique": true,
            "columns": [
                "createdAt",
                "id"
            ]
        }
    },
    "serviceClassName": "Espo\\Custom\\Services\\CAttendance",
    "optimisticConcurrencyControl": false
}