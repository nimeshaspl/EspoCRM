{
    "fields": {
        "name": {
            "type": "varchar",
            "required": true,
            "pattern": "$noBadCharacters"
        },
        "description": {
            "type": "text"
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true
        },
        "createdBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "assignedUser": {
            "type": "link",
            "required": false,
            "view": "views/fields/assigned-user"
        },
        "teams": {
            "type": "linkMultiple",
            "view": "views/fields/teams"
        },
        "isPayrollClose": {
            "notNull": true,
            "type": "bool",
            "isCustom": true
        },
        "employee": {
            "type": "link"
        },
        "date": {
            "notNull": false,
            "type": "date",
            "isCustom": true
        },
        "totalEmployees": {
            "type": "int",
            "isCustom": true
        },
        "wageAmount": {
            "type": "currency",
            "isCustom": true
        },
        "salaryPayout": {
            "type": "currency",
            "isCustom": true
        },
        "taxPayment": {
            "type": "currency",
            "isCustom": true
        },
        "pTGross": {
            "type": "currency",
            "isCustom": true
        }
    },
    "links": {
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "assignedUser": {
            "type": "belongsTo",
            "entity": "User"
        },
        "teams": {
            "type": "hasMany",
            "entity": "Team",
            "relationName": "entityTeam",
            "layoutRelationshipsDisabled": true
        },
        "employee": {
            "type": "belongsTo",
            "foreign": "payrolls",
            "entity": "CEmployee",
            "audited": false,
            "isCustom": true
        },
        "payrollIssues": {
            "type": "hasMany",
            "foreign": "payroll",
            "entity": "CPayrollIssue",
            "audited": false,
            "isCustom": true
        }
    },
    "collection": {
        "orderBy": "createdAt",
        "order": "desc"
    },
    "indexes": {
        "name": {
            "columns": [
                "name",
                "deleted"
            ]
        },
        "assignedUser": {
            "columns": [
                "assignedUserId",
                "deleted"
            ]
        },
        "createdAt": {
            "columns": [
                "createdAt"
            ]
        },
        "createdAtId": {
            "unique": true,
            "columns": [
                "createdAt",
                "id"
            ]
        }
    },
    "serviceClassName": "Espo\\Custom\\Services\\CPayroll"
}