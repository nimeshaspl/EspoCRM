{
    "fields": {
        "name": {
            "type": "varchar",
            "required": true,
            "pattern": "$noBadCharacters",
            "options": []
        },
        "description": {
            "type": "text"
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true
        },
        "createdBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "assignedUser": {
            "type": "link",
            "required": false,
            "view": "views/fields/assigned-user"
        },
        "teams": {
            "type": "linkMultiple",
            "view": "views/fields/teams"
        },
        "callDate": {
            "notNull": false,
            "type": "datetime",
            "required": true,
            "minuteStep": 30,
            "isCustom": true,
            "default": "javascript: return this.dateTime.getNow(1);"
        },
        "status": {
            "type": "enum",
            "required": true,
            "options": [
                "Held",
                "Not Connected",
                "Call disconnected"
            ],
            "style": {
                "Held": null,
                "Not Connected": null,
                "Call disconnected": null
            },
            "default": "Held",
            "isCustom": true
        },
        "candidateManagements": {
            "type": "linkMultiple",
            "layoutDetailDisabled": false,
            "layoutMassUpdateDisabled": false,
            "layoutListDisabled": false,
            "noLoad": false,
            "importDisabled": false,
            "exportDisabled": false,
            "customizationDisabled": false,
            "isCustom": true
        },
        "source": {
            "type": "enum",
            "required": true,
            "options": [
                "Call",
                "Email",
                "Linkedin"
            ],
            "style": {
                "Call": null,
                "Email": null,
                "Linkedin": null
            },
            "default": "Call",
            "isCustom": true
        }
    },
    "links": {
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "assignedUser": {
            "type": "belongsTo",
            "entity": "User"
        },
        "teams": {
            "type": "hasMany",
            "entity": "Team",
            "relationName": "entityTeam",
            "layoutRelationshipsDisabled": true
        },
        "candidateManagements": {
            "type": "hasMany",
            "relationName": "candidateManagementRecruitementCall",
            "foreign": "recruitementCalls",
            "entity": "CandidateManagement",
            "audited": false,
            "isCustom": true
        }
    },
    "collection": {
        "orderBy": "createdAt",
        "order": "desc"
    },
    "indexes": {
        "name": {
            "columns": [
                "name",
                "deleted"
            ]
        },
        "assignedUser": {
            "columns": [
                "assignedUserId",
                "deleted"
            ]
        },
        "createdAt": {
            "columns": [
                "createdAt"
            ]
        },
        "createdAtId": {
            "unique": true,
            "columns": [
                "createdAt",
                "id"
            ]
        }
    }
}