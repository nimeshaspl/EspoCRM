{
    "fields": {
        "name": {
            "type": "varchar",
            "required": true,
            "pattern": "$noBadCharacters",
            "options": []
        },
        "description": {
            "type": "text"
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true
        },
        "createdBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "assignedUser": {
            "type": "link",
            "required": false,
            "view": "views/fields/assigned-user"
        },
        "teams": {
            "type": "linkMultiple",
            "view": "views/fields/teams",
            "required": false
        },
        "startDate": {
            "notNull": false,
            "type": "date",
            "required": true,
            "audited": true,
            "tooltip": true,
            "isCustom": true
        },
        "endDate": {
            "notNull": false,
            "type": "date",
            "required": true,
            "tooltip": true,
            "isCustom": true
        },
        "plannedHour": {
            "notNull": false,
            "type": "float",
            "required": true,
            "audited": true,
            "isCustom": true
        },
        "contact": {
            "type": "link"
        },
        "status": {
            "type": "enum",
            "required": true,
            "options": [
                "Draft",
                "Documentation",
                "In-Progress",
                "UAT",
                "Support",
                "Completed",
                "On Hold",
                "Cancelled"
            ],
            "style": {
                "Draft": null,
                "Documentation": "primary",
                "In-Progress": "warning",
                "UAT": "success",
                "Support": "success",
                "Completed": "success",
                "On Hold": "info",
                "Cancelled": "danger"
            },
            "default": "Draft",
            "audited": true,
            "isCustom": true,
            "displayAsLabel": true
        },
        "actualHours": {
            "type": "enum",
            "readOnly": true,
            "style": [],
            "isCustom": true
        },
        "projectDocuments": {
            "type": "file",
            "sourceList": [
                "Document"
            ],
            "maxFileSize": 10,
            "accept": [
                "image/*",
                "video/*",
                ".pdf",
                ".docx",
                ".pptx",
                ".doc",
                ".xlsx",
                ".xls",
                ".ppt"
            ],
            "isCustom": true
        },
        "milestones": {
            "type": "linkMultiple",
            "layoutDetailDisabled": false,
            "layoutMassUpdateDisabled": false,
            "layoutListDisabled": false,
            "noLoad": false,
            "importDisabled": false,
            "exportDisabled": false,
            "customizationDisabled": true,
            "isCustom": true
        },
        "projectTasks": {
            "type": "linkMultiple",
            "layoutDetailDisabled": false,
            "layoutMassUpdateDisabled": false,
            "layoutListDisabled": false,
            "noLoad": false,
            "importDisabled": false,
            "exportDisabled": false,
            "customizationDisabled": true,
            "isCustom": true
        },
        "projectUpdates": {
            "type": "linkMultiple",
            "layoutDetailDisabled": false,
            "layoutMassUpdateDisabled": false,
            "layoutListDisabled": false,
            "noLoad": false,
            "importDisabled": false,
            "exportDisabled": false,
            "customizationDisabled": true,
            "isCustom": true
        },
        "bugTrackers": {
            "type": "linkMultiple",
            "layoutDetailDisabled": true,
            "layoutMassUpdateDisabled": true,
            "layoutListDisabled": true,
            "noLoad": true,
            "importDisabled": true,
            "exportDisabled": true,
            "customizationDisabled": true,
            "isCustom": true
        },
        "timesheets": {
            "type": "linkMultiple",
            "layoutDetailDisabled": true,
            "layoutMassUpdateDisabled": true,
            "layoutListDisabled": true,
            "noLoad": true,
            "importDisabled": true,
            "exportDisabled": true,
            "customizationDisabled": true,
            "isCustom": true
        },
        "managerMappings": {
            "type": "linkMultiple",
            "layoutDetailDisabled": true,
            "layoutMassUpdateDisabled": true,
            "layoutListDisabled": true,
            "noLoad": true,
            "importDisabled": true,
            "exportDisabled": true,
            "customizationDisabled": true,
            "isCustom": true
        },
        "totalBudgetUtilized": {
            "notNull": false,
            "type": "float",
            "readOnly": true,
            "isCustom": true,
            "decimalPlaces": 2
        },
        "totalBudget": {
            "notNull": false,
            "type": "float",
            "isCustom": true
        }
    },
    "links": {
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "assignedUser": {
            "type": "belongsTo",
            "entity": "User"
        },
        "teams": {
            "type": "hasMany",
            "entity": "Team",
            "relationName": "entityTeam",
            "layoutRelationshipsDisabled": true
        },
        "contact": {
            "type": "belongsTo",
            "foreign": "projects",
            "entity": "Contact",
            "audited": false,
            "isCustom": true
        },
        "projectDocuments": {
            "type": "belongsTo",
            "entity": "Attachment",
            "skipOrmDefs": true,
            "utility": true
        },
        "milestones": {
            "type": "hasMany",
            "foreign": "project",
            "entity": "Milestone",
            "audited": false,
            "isCustom": true
        },
        "projectTasks": {
            "type": "hasMany",
            "foreign": "project",
            "entity": "ProjectTask",
            "audited": false,
            "isCustom": true
        },
        "projectUpdates": {
            "type": "hasMany",
            "foreign": "project",
            "entity": "ProjectUpdate",
            "audited": false,
            "isCustom": true
        },
        "bugTrackers": {
            "type": "hasMany",
            "foreign": "project",
            "entity": "BugTracker",
            "audited": false,
            "isCustom": true
        },
        "timesheets": {
            "type": "hasMany",
            "foreign": "project",
            "entity": "Timesheet",
            "audited": false,
            "isCustom": true
        },
        "managerMappings": {
            "type": "hasMany",
            "foreign": "project",
            "entity": "ManagerMapping",
            "audited": false,
            "isCustom": true
        },
        "workToBeBills": {
            "type": "hasMany",
            "foreign": "project",
            "entity": "CWorkToBeBill",
            "audited": false,
            "isCustom": true
        },
        "cRTrackings": {
            "type": "hasMany",
            "foreign": "project",
            "entity": "CCRTracking",
            "audited": false,
            "isCustom": true
        }
    },
    "collection": {
        "orderBy": "createdAt",
        "order": "desc",
        "textFilterFields": [
            "name"
        ],
        "fullTextSearch": false,
        "countDisabled": false
    },
    "indexes": {
        "name": {
            "columns": [
                "name",
                "deleted"
            ]
        },
        "assignedUser": {
            "columns": [
                "assignedUserId",
                "deleted"
            ]
        },
        "createdAt": {
            "columns": [
                "createdAt"
            ]
        },
        "createdAtId": {
            "unique": true,
            "columns": [
                "createdAt",
                "id"
            ]
        }
    },
    "optimisticConcurrencyControl": false
}