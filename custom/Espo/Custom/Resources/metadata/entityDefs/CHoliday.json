{
    "fields": {
        "name": {
            "type": "varchar",
            "required": true,
            "pattern": "$noBadCharacters"
        },
        "description": {
            "type": "text"
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true
        },
        "createdBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "assignedUser": {
            "type": "link",
            "required": false,
            "view": "views/fields/assigned-user"
        },
        "teams": {
            "type": "linkMultiple",
            "view": "views/fields/teams"
        },
        "holidayImage": {
            "type": "image",
            "previewSize": "small",
            "isCustom": true
        },
        "date": {
            "notNull": false,
            "type": "date",
            "isCustom": true
        },
        "isSelected": {
            "notNull": true,
            "type": "bool",
            "isCustom": true
        },
        "type": {
            "type": "enum",
            "options": [
                "Optional",
                "Mandatory"
            ],
            "style": {
                "Optional": null,
                "Mandatory": null
            },
            "default": "Optional",
            "maxLength": 100,
            "isCustom": true
        },
        "location": {
            "type": "enum",
            "options": [
                "India",
                "USA",
                "Both"
            ],
            "style": {
                "India": null,
                "USA": null,
                "Both": null
            },
            "default": "India",
            "maxLength": 100,
            "isCustom": true
        },
        "user": {
            "type": "link"
        }
    },
    "links": {
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "assignedUser": {
            "type": "belongsTo",
            "entity": "User"
        },
        "teams": {
            "type": "hasMany",
            "entity": "Team",
            "relationName": "entityTeam",
            "layoutRelationshipsDisabled": true
        },
        "holidayImage": {
            "type": "belongsTo",
            "entity": "Attachment",
            "skipOrmDefs": true,
            "utility": true
        },
        "user": {
            "type": "belongsTo",
            "foreign": "cHoliday",
            "entity": "User",
            "audited": false,
            "isCustom": true
        },
        "holidaySelections": {
            "type": "hasMany",
            "foreign": "holiday",
            "entity": "CHolidaySelection",
            "audited": false,
            "isCustom": true
        }
    },
    "collection": {
        "orderBy": "createdAt",
        "order": "desc"
    },
    "indexes": {
        "name": {
            "columns": [
                "name",
                "deleted"
            ]
        },
        "assignedUser": {
            "columns": [
                "assignedUserId",
                "deleted"
            ]
        },
        "createdAt": {
            "columns": [
                "createdAt"
            ]
        },
        "createdAtId": {
            "unique": true,
            "columns": [
                "createdAt",
                "id"
            ]
        }
    }
}