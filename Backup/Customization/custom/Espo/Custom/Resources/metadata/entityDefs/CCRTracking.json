{
    "fields": {
        "name": {
            "type": "varchar",
            "required": true,
            "pattern": "$noBadCharacters"
        },
        "description": {
            "type": "text"
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true
        },
        "createdBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "assignedUser": {
            "type": "link",
            "required": false,
            "view": "views/fields/assigned-user"
        },
        "teams": {
            "type": "linkMultiple",
            "view": "views/fields/teams"
        },
        "supportiveDocument": {
            "type": "file",
            "sourceList": [
                "Document"
            ],
            "accept": [
                ".pdf"
            ],
            "isCustom": true
        },
        "hours": {
            "notNull": false,
            "type": "float",
            "min": 1,
            "decimalPlaces": 1,
            "tooltip": true,
            "isCustom": true
        },
        "status": {
            "type": "enum",
            "options": [
                "Pending",
                "Approved",
                "Rejected",
                "On Hold"
            ],
            "style": {
                "Pending": null,
                "Approved": null,
                "Rejected": null,
                "On Hold": null
            },
            "default": "Pending",
            "maxLength": 100,
            "isCustom": true
        },
        "amount": {
            "type": "currency",
            "isCustom": true
        },
        "project": {
            "type": "link"
        }
    },
    "links": {
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "assignedUser": {
            "type": "belongsTo",
            "entity": "User"
        },
        "teams": {
            "type": "hasMany",
            "entity": "Team",
            "relationName": "entityTeam",
            "layoutRelationshipsDisabled": true
        },
        "supportiveDocument": {
            "type": "belongsTo",
            "entity": "Attachment",
            "skipOrmDefs": true,
            "utility": true
        },
        "project": {
            "type": "belongsTo",
            "foreign": "cRTrackings",
            "entity": "Project",
            "audited": true,
            "isCustom": true
        }
    },
    "collection": {
        "orderBy": "createdAt",
        "order": "desc"
    },
    "indexes": {
        "name": {
            "columns": [
                "name",
                "deleted"
            ]
        },
        "assignedUser": {
            "columns": [
                "assignedUserId",
                "deleted"
            ]
        },
        "createdAt": {
            "columns": [
                "createdAt"
            ]
        },
        "createdAtId": {
            "unique": true,
            "columns": [
                "createdAt",
                "id"
            ]
        }
    }
}