{
    "fields": {
        "name": {
            "type": "varchar",
            "required": true,
            "pattern": "$noBadCharacters",
            "options": []
        },
        "description": {
            "type": "text"
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true
        },
        "createdBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "assignedUser": {
            "type": "link",
            "required": false,
            "view": "views/fields/assigned-user"
        },
        "teams": {
            "type": "linkMultiple",
            "view": "views/fields/teams",
            "readOnly": true
        },
        "startDate": {
            "notNull": false,
            "type": "date",
            "required": true,
            "audited": true,
            "isCustom": true
        },
        "endDate": {
            "notNull": false,
            "type": "date",
            "required": true,
            "isCustom": true
        },
        "totalHours": {
            "notNull": false,
            "type": "float",
            "readOnly": true,
            "isCustom": true
        },
        "totalTask": {
            "type": "int",
            "readOnly": true,
            "isCustom": true
        },
        "pendingTask": {
            "type": "int",
            "readOnly": true,
            "isCustom": true
        },
        "completedTask": {
            "type": "int",
            "readOnly": true,
            "isCustom": true
        },
        "inProgressTask": {
            "type": "int",
            "readOnly": true,
            "isCustom": true
        },
        "totalBugs": {
            "type": "int",
            "readOnly": true,
            "isCustom": true
        },
        "project": {
            "type": "link"
        },
        "documents": {
            "type": "file",
            "maxFileSize": 10,
            "accept": [
                "image/*",
                "video/*",
                ".zip",
                ".pdf",
                ".docx",
                ".xlsx",
                ".pptx",
                ".doc",
                ".xls",
                ".ppt",
                ".csv"
            ],
            "sourceList": [],
            "isCustom": true
        },
        "projectTasks": {
            "type": "linkMultiple",
            "layoutDetailDisabled": false,
            "layoutMassUpdateDisabled": false,
            "layoutListDisabled": false,
            "noLoad": false,
            "importDisabled": false,
            "exportDisabled": false,
            "customizationDisabled": true,
            "isCustom": true
        },
        "account": {
            "type": "link",
            "readOnly": true
        }
    },
    "links": {
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "assignedUser": {
            "type": "belongsTo",
            "entity": "User"
        },
        "teams": {
            "type": "hasMany",
            "entity": "Team",
            "relationName": "entityTeam",
            "layoutRelationshipsDisabled": true
        },
        "project": {
            "type": "belongsTo",
            "foreign": "milestones",
            "entity": "Project",
            "audited": true,
            "isCustom": true
        },
        "documents": {
            "type": "belongsTo",
            "entity": "Attachment",
            "skipOrmDefs": true,
            "utility": true
        },
        "projectTasks": {
            "type": "hasMany",
            "foreign": "milestone",
            "entity": "ProjectTask",
            "audited": false,
            "isCustom": true
        },
        "account": {
            "type": "belongsTo",
            "foreign": "milestones",
            "entity": "Account",
            "audited": false,
            "isCustom": true
        }
    },
    "collection": {
        "orderBy": "createdAt",
        "order": "desc"
    },
    "indexes": {
        "name": {
            "columns": [
                "name",
                "deleted"
            ]
        },
        "assignedUser": {
            "columns": [
                "assignedUserId",
                "deleted"
            ]
        },
        "createdAt": {
            "columns": [
                "createdAt"
            ]
        },
        "createdAtId": {
            "unique": true,
            "columns": [
                "createdAt",
                "id"
            ]
        }
    }
}