{
    "fields": {
        "name": {
            "type": "varchar",
            "required": true,
            "pattern": "$noBadCharacters"
        },
        "description": {
            "type": "text"
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true
        },
        "createdBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "assignedUser": {
            "type": "link",
            "required": false,
            "view": "views/fields/assigned-user"
        },
        "teams": {
            "type": "linkMultiple",
            "view": "views/fields/teams"
        },
        "assetType": {
            "type": "enum",
            "required": true,
            "options": [
                "Computer",
                "Laptop",
                "Mouse",
                "MousePad",
                "Charger",
                "Head Phone",
                "LED",
                "Keyboard",
                "Other",
                "Lan Cable",
                "Printer"
            ],
            "style": {
                "Computer": null,
                "Laptop": null,
                "Mouse": null,
                "MousePad": null,
                "Charger": null,
                "Head Phone": null,
                "LED": null,
                "Keyboard": null,
                "Other": null,
                "Lan Cable": null,
                "Printer": null
            },
            "default": "Computer",
            "isCustom": true
        },
        "vendorName": {
            "type": "enum",
            "options": [
                "None",
                "Arnam Solutions",
                "Namrata Solutions",
                "Solutions 365"
            ],
            "style": {
                "None": null,
                "Arnam Solutions": null,
                "Namrata Solutions": null,
                "Solutions 365": null
            },
            "default": "None",
            "isCustom": true
        },
        "purchaseDate": {
            "notNull": false,
            "type": "date",
            "isCustom": true
        },
        "warrantyEndDate": {
            "notNull": false,
            "type": "date",
            "isCustom": true
        },
        "rAM": {
            "type": "int",
            "isCustom": true
        },
        "processor": {
            "type": "enum",
            "options": [
                "None",
                "I3",
                "I5",
                "I7",
                "AMD",
                "Dual Core"
            ],
            "style": {
                "None": null,
                "I3": null,
                "I5": null,
                "I7": null,
                "AMD": null,
                "Dual Core": null
            },
            "default": "I3",
            "isCustom": true
        },
        "hardDiskSize": {
            "type": "int",
            "isCustom": true
        },
        "brand": {
            "type": "enum",
            "options": [
                "Other",
                "Dell",
                "HP",
                "Asus",
                "Apple",
                "Logitech"
            ],
            "style": {
                "Other": null,
                "Dell": null,
                "HP": null,
                "Asus": null,
                "Apple": null,
                "Logitech": null
            },
            "default": "Dell",
            "isCustom": true
        },
        "invoiceNumber": {
            "type": "text",
            "rowsMin": 2,
            "cutHeight": 200,
            "isCustom": true
        },
        "warratyActive": {
            "notNull": true,
            "type": "bool",
            "isCustom": true
        },
        "isDamaged": {
            "notNull": true,
            "type": "bool",
            "isCustom": true
        },
        "invoiceCopy": {
            "type": "file",
            "sourceList": [
                "Document"
            ],
            "accept": [],
            "isCustom": true
        }
    },
    "links": {
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "assignedUser": {
            "type": "belongsTo",
            "entity": "User"
        },
        "teams": {
            "type": "hasMany",
            "entity": "Team",
            "relationName": "entityTeam",
            "layoutRelationshipsDisabled": true
        },
        "invoiceCopy": {
            "type": "belongsTo",
            "entity": "Attachment",
            "skipOrmDefs": true,
            "disabled": true
        }
    },
    "collection": {
        "orderBy": "createdAt",
        "order": "desc",
        "textFilterFields": [
            "name"
        ],
        "fullTextSearch": true,
        "countDisabled": false
    },
    "indexes": {
        "name": {
            "columns": [
                "name",
                "deleted"
            ]
        },
        "assignedUser": {
            "columns": [
                "assignedUserId",
                "deleted"
            ]
        },
        "createdAt": {
            "columns": [
                "createdAt"
            ]
        },
        "createdAtId": {
            "unique": true,
            "columns": [
                "createdAt",
                "id"
            ]
        }
    },
    "optimisticConcurrencyControl": false
}